    "%@ · %@" : {
      "comment" : "A subheading that describes the duration and distance of a car ride. The first argument is the string “%1$d:%2$02d:%3$02d” or the string “%1$d:%2$02d”. The second argument is the string “%.1f km”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ · %lld km/s" : {
      "comment" : "A label displaying the elapsed time and speed of a live activity. The argument is the string “%1$d:%2$02d:%3$02d” or the string “%1$d:%2$02d”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$lld km/s"
          }
        }
      }
    },
    "%@ / %@" : {
      "comment" : "A label displaying the user's monthly distance goal in kilometers. The first argument is the user's current monthly distance goal in kilometers. The second argument is the user's monthly distance goal in kilometers.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ / %2$@"
          }
        }
      }
    },
    "%@: %@" : {
      "comment" : "A label that combines a label and a value. The first argument is the label, the second argument is the value. The second argument is the string “%1$arg %2$arg”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$@"
          }
        }
      }
    },
